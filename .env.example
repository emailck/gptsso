PORT=3000
HOST=127.0.0.1
ISSUER=https://auth.your-domain.com
# Backward-compatible single-client config. Leave these set if you only have one ChatGPT workspace.
VERIFIED_DOMAIN=your-domain.com
OIDC_CLIENT_ID=chatgpt-client-id
OIDC_CLIENT_SECRET=replace-with-a-long-random-secret
ALLOWED_REDIRECT_URIS=https://replace-with-openai-redirect-uri.example/callback

# Preferred multi-workspace config. If set, this overrides the single-client values above.
# Use one entry per ChatGPT Business/Team workspace. Each verified_domain must be verified
# in the corresponding OpenAI Admin Console workspace.
# OIDC_CLIENTS_JSON={"chatgpt-team-a":{"client_secret":"replace-with-a-long-random-secret-a","verified_domain":"team-a.com","allowed_redirect_uris":["https://openai-callback-a.example/callback"]},"chatgpt-team-b":{"client_secret":"replace-with-a-long-random-secret-b","verified_domain":"team-b.com","allowed_redirect_uris":["https://openai-callback-b.example/callback"]}}

ADMIN_TOKEN=replace-with-a-long-random-admin-token
DATA_DIR=./data
